{
  "name": "ndaru-portfolio",
  "version": "1.0.0",
  "description": "Bilingual product design and software engineering portfolio powered by Next.js and Firebase.",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "mv src/app/admin src/.admin-temp 2>/dev/null || true; next build; mv src/.admin-temp src/app/admin 2>/dev/null || true",
    "start": "npx --yes serve@latest out",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "test:rules": "npm --prefix security_rules_test_firestore test",
    "deploy:rules": "npx -y firebase-tools@latest deploy --only firestore:rules --project ndaru-portfolio",
    "deploy:hosting": "npx -y firebase-tools@latest deploy --only hosting --project ndaru-portfolio",
    "deploy": "npm run build && npm run deploy:hosting"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.8.0",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.562.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
